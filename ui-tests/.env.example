# Copy this file to ui-tests/.env and fill in real values.
# ui-tests/.env is gitignored and must never be committed.

# Base URL of the running app (no trailing slash).
# The signin page is expected at ${BASE_URL}/pspf_crm/api/signin/index.php
BASE_URL=http://hpkprd

# Optional: a throwaway test account. Enables the read-only authenticated
# tests (login lands on the right dashboard, ticket form renders).
# Leave both blank to run only the page-load and invalid-login checks.
TEST_EMAIL=
TEST_PASSWORD=

# Optional: for accounts with more than one role, which role to pick on the
# chooser (user | agent | admin | superadmin). Defaults to the first card.
TEST_ROLE=

# Optional and OFF by default. Set to 1 to also run the create-ticket flow.
# WARNING: this writes a real ticket AND sends confirmation/assignment emails.
# Do not enable for daily production runs unless you want a ticket + emails
# every day.
RUN_WRITE_TESTS=
